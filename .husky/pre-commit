#!/usr/bin/env sh
# 스테이징된 src/content/posts/ 아래 글(.md/.mdx)의 날짜 frontmatter를 자동 처리한다.
# (Windows에서는 Git for Windows의 sh로 실행됨)
#
# 1) pubDatetime(작성일): 새로 추가되거나 수정된 글에서 값이 비어있거나 키가 없으면
#    현재 UTC로 채운다. 이미 값이 있으면 보존한다. draft 여부와 무관하게 적용한다.
# 2) modDatetime(수정일): 수정된(draft: false) 글의 modDatetime을 현재 UTC로 갱신한다.
#    modDatetime 키가 있으면 값 갱신, 없으면 pubDatetime 아래에 추가한다.

now=$(date -u "+%Y-%m-%dT%H:%M:%SZ")

git diff --cached --name-status --diff-filter=AM -- src/content/posts | while read -r status file; do
  case "$file" in
    *.md | *.mdx) ;;
    *) continue ;;
  esac
  [ -f "$file" ] || continue

  changed=""

  # --- 1) pubDatetime(작성일) 자동 채우기 ---
  # 첫 frontmatter 블록에서 pubDatetime 상태를 판별한다: filled / blank / missing
  pubstate=$(awk '
    /^---[[:space:]]*$/ { c++; if (c>=2) exit; next }
    c==1 && /^pubDatetime:[[:space:]]*$/ { state="blank"; exit }
    c==1 && /^pubDatetime:/ { state="filled"; exit }
    END { print (state=="" ? "missing" : state) }
  ' "$file")

  if [ "$pubstate" = "blank" ]; then
    tmp=$(mktemp)
    awk -v now="$now" '
      !done && /^pubDatetime:[[:space:]]*$/ { print "pubDatetime: " now; done=1; next }
      { print }
    ' "$file" >"$tmp"
    mv "$tmp" "$file"
    changed="pubDatetime"
  elif [ "$pubstate" = "missing" ]; then
    tmp=$(mktemp)
    awk -v now="$now" '
      { print }
      !done && /^---[[:space:]]*$/ { print "pubDatetime: " now; done=1 }
    ' "$file" >"$tmp"
    mv "$tmp" "$file"
    changed="pubDatetime"
  fi

  # --- 2) modDatetime(수정일) 갱신: 수정된(M) 글이고 draft: false 일 때만 ---
  if [ "$status" = "M" ]; then
    draft=$(awk '
      /^---[[:space:]]*$/ { c++; next }
      c==1 && /^draft:/ { v=$0; sub(/^draft:[[:space:]]*/,"",v); print v; exit }
    ' "$file")

    if [ "$draft" = "false" ]; then
      tmp=$(mktemp)
      if grep -qE '^modDatetime:' "$file"; then
        awk -v now="$now" '
          !done && /^modDatetime:/ { print "modDatetime: " now; done=1; next }
          { print }
        ' "$file" >"$tmp"
      else
        awk -v now="$now" '
          { print }
          !done && /^pubDatetime:/ { print "modDatetime: " now; done=1 }
        ' "$file" >"$tmp"
      fi
      mv "$tmp" "$file"
      changed="${changed:+$changed, }modDatetime"
    fi
  fi

  if [ -n "$changed" ]; then
    git add "$file"
    echo "pre-commit: $changed -> $now  ($file)"
  fi
done
